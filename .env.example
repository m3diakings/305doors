# Public site URL (must match the browser origin for lead form POSTs in production)
NEXT_PUBLIC_SITE_URL=https://www.305doors.com

# Google Analytics 4 — Admin → Data streams → Web → Measurement ID (G-...)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Lead delivery (use any combination) ---

# Optional: Zapier / Slack / CRM webhook (JSON POST)
# LEAD_WEBHOOK_URL=

# Resend (https://resend.com) — verify your sending domain first
# RESEND_API_KEY=re_...
# LEAD_EMAIL_TO=you@yourdomain.com
# LEAD_EMAIL_FROM=305 Doors <leads@yourdomain.com>

# Optional: reject requests with no Origin header (blocks some scripts; not curl)
# LEAD_REQUIRE_ORIGIN=1

# Optional: extra allowed Origins for /api/lead (comma-separated). Production URL is always allowed;
# Vercel preview/prod deployments are allowed automatically via VERCEL_URL.
# LEAD_ALLOWED_ORIGINS=https://staging.example.com

# --- Zoho CRM (optional) — creates a Lead when the quote form is submitted
# Register a "Server-based" client at https://api-console.zoho.com
# OAuth scope (example): ZohoCRM.modules.leads.CREATE
# Generate a refresh token using Zoho’s OAuth steps (authorization code → exchange for refresh_token).
# Never commit real tokens — set these only in .env / hosting secrets.
#
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=
#
# If your org is in the EU or India, set both domains (examples):
# ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.eu
# ZOHO_CRM_API_DOMAIN=https://www.zohoapis.eu
#
# Optional: must match a Lead Source picklist value in Zoho (or add "Website" there)
# ZOHO_LEAD_SOURCE=Website
#
# Optional: API module name (default Leads). Contacts uses different field API names.
# ZOHO_CRM_MODULE=Leads

# --- Supabase (optional) — stores each quote in public.leads (see supabase/migrations)
# Project URL from Supabase → Settings → API (public URL is fine; secret key stays server-only)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Optional fallback if you keep URL server-only:
# SUPABASE_URL=https://xxxx.supabase.co
# Server-only: never expose this key to the browser (service_role JWT or sb_secret_…, not anon)
# SUPABASE_SERVICE_ROLE_KEY=
# Optional: table name if not using default "leads"
# SUPABASE_LEADS_TABLE=leads
